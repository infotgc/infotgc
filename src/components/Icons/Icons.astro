---
import { icons, type IconName } from "./icons";

interface Props {
    name: IconName;
    size?: number;
    class?: string;
}

const {
    name,
    size = 28,
    class: className = ""
} = Astro.props;

const icon = icons[name];
---

<svg
    class={className}
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.7"
    stroke-linecap="round"
    stroke-linejoin="round"
    set:html={icon}
/>