---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Page introuvable">

<main class="not-found">

    <div class="container">

        <h1>404</h1>

        <h2>Page introuvable</h2>

        <p>

            La page que vous recherchez n'existe pas
            ou a été déplacée.

        </p>

        <a class="btn" href="/">

            Retour à l'accueil

        </a>

    </div>

</main>

</Layout>